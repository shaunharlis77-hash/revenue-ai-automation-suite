            }
          ]
        },
        "options": {}
      },
      "id": "run-full-demo",
      "name": "Run Full Demo Story API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [560, 340]
    },
    {
      "parameters": {
