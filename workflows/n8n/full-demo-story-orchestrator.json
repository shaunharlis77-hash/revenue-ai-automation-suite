        "responseBody": "={{$json}}"
      },
      "id": "return-demo-result",
      "name": "Return Demo Result",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [830, 420]
    }
  ],
  "connections": {
    "Manual Demo Trigger": {
      "main": [[{"node": "Run Full Demo Story API", "type": "main", "index": 0}]]
    },
    "Webhook Demo Trigger": {
      "main": [[{"node": "Run Full Demo Story API", "type": "main", "index": 0}]]
    },
    "Run Full Demo Story API": {
      "main": [[{"node": "Return Demo Result", "type": "main", "index": 0}]]
